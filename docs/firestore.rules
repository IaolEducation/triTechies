rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is the Super Admin or a whitelisted Admin
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'techiestri@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
      );
    }
    
    // Helper function to check if the user is the Super Admin
    function isSuperAdmin() {
      return request.auth != null && request.auth.token.email == 'techiestri@gmail.com';
    }

    // Projects Collection
    match /projects/{document=**} {
      // Anyone can read the projects for the landing page
      allow read: if true;
      // Only authenticated admins can modify
      allow write: if isAdmin();
    }

    // Team Collection
    match /team/{document=**} {
      // Anyone can read the team members for the landing page
      allow read: if true;
      // Only authenticated admins can modify
      allow write: if isAdmin();
    }

    // Contacts / Leads Collection
    match /contacts/{document=**} {
      // Anyone can submit a contact form
      allow create: if true;
      // Only authenticated admins can read or modify leads
      allow read, update, delete: if isAdmin();
    }

    // Admins Whitelist Collection
    match /admins/{email} {
      // Any logged in user can read their own admin document to check access status
      allow read: if request.auth != null && request.auth.token.email == email;
      // Only the Super Admin can write/manage whitelisted admins
      allow read, write: if isSuperAdmin();
    }
    
    // Site Config Collection (spots availability, month, etc.)
    match /siteConfig/{document=**} {
      // Anyone can read for the public hero badge
      allow read: if true;
      // Only authenticated admins can modify
      allow write: if isAdmin();
    }

    // Default catch-all rule: Deny access to anything not explicitly allowed above
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
