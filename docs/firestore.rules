rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Only authenticated admins can read/write to the entire database
    // For read access to public collections like `projects` and `team`, we allow anyone reading.
    
    // Projects Collection
    match /projects/{document=**} {
      // Anyone can read the projects for the landing page
      allow read: if true;
      // Only authenticated users (admins) can modify
      allow write: if request.auth != null;
    }

    // Team Collection
    match /team/{document=**} {
      // Anyone can read the team members for the landing page
      allow read: if true;
      // Only authenticated users (admins) can modify
      allow write: if request.auth != null;
    }

    // Contacts / Leads Collection
    match /contacts/{document=**} {
      // Anyone can submit a contact form
      allow create: if true;
      // Only authenticated users (admins) can read or modify leads
      allow read, update, delete: if request.auth != null;
    }
    
    // Default catch-all rule: Deny access to anything not explicitly allowed above
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
